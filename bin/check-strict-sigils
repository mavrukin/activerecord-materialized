#!/usr/bin/env bash
set -euo pipefail

if [[ "$#" -eq 0 ]]; then
  files=$(git ls-files "lib/**/*.rb")
else
  files="$*"
fi

failed=0

for file in $files; do
  [[ -f "$file" ]] || continue
  first_line=$(head -n 1 "$file")
  if [[ "$first_line" != "# typed: strict" ]]; then
    echo "ERROR: $file must start with '# typed: strict' (found: '$first_line')"
    failed=1
  fi
done

if [[ "$failed" -ne 0 ]]; then
  echo
  echo "All lib/**/*.rb files must use '# typed: strict'. No typed: true or typed: false allowed."
  exit 1
fi

echo "All checked files use # typed: strict"
