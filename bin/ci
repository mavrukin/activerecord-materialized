#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

echo "==> RuboCop"
# Lint the whole project (specs, Rakefile, gemspec, top-level scripts) per .rubocop.yml's
# Include/Exclude — not just lib/ bin/ — so a spec offense can't pass this "full local gate".
bundle exec rubocop --parallel

# Mirror CI (.github/workflows/ci.yml): the heavy benchmark integration
# spec leaks state across the random-ordered suite, so CI runs the fast
# suite and that spec in separate jobs. Do the same here for a reliable
# local gate. The benchmark spec self-skips unless `rake benchmark:setup`
# has produced the fixture database.
HEAVY_SPEC="spec/active_record/materialized/async_refresher_flush_spec.rb"

# The fast run excludes the real-DB matrix specs by tag (:db_matrix) — they need
# MySQL/Postgres containers (see .github/workflows/db-*.yml). The pure-Ruby registry
# unit spec (integration_adapters_spec) is untagged and stays in the fast gate.
echo "==> RSpec"
bundle exec rspec --exclude-pattern "$HEAVY_SPEC" --tag '~db_matrix'

echo "==> RSpec (benchmark integration, isolated)"
bundle exec rspec "$HEAVY_SPEC"

echo "==> All checks passed"
