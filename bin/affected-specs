#!/usr/bin/env ruby
# frozen_string_literal: true

FAST_SPEC_DIR = "spec/active_record/materialized"
HEAVY_SPEC = File.join(FAST_SPEC_DIR, "async_refresher_flush_spec.rb")
ALL_FAST_SPECS = Dir[File.join(FAST_SPEC_DIR, "*_spec.rb")].reject { |path| path == HEAVY_SPEC }.sort.freeze
INFRA_TRIGGER = %r{\A(?:Gemfile|activerecord-materialized\.gemspec|\.rubocop|lefthook|sorbet|\.github/workflows)}

# Non-obvious lib file → spec mappings. :all runs the full fast suite.
SPEC_OVERRIDES = {
  "async_refresher" => %w[view_refresh_on_change_spec.rb],
  "refresh_scheduler" => %w[view_refresh_on_change_spec.rb],
  "refresh_job" => %w[view_refresh_on_change_spec.rb],
  "relation_cache_writer" => %w[refresher_spec.rb incremental_maintainer_spec.rb],
  "cache_table_schema" => %w[refresher_spec.rb],
  "install_hooks" => :all,
  "dependency_registry" => :all,
  "dependency_trackable" => :all,
  "table_model_registry" => :all,
  "write_change" => %w[maintenance_delta_builder_spec.rb maintenance_delta_spec.rb],
  "maintenance_store" => %w[maintenance_delta_spec.rb],
  "query_expressions" => %w[view_definition_spec.rb],
  "view_configuration_class_methods" => %w[view_spec.rb],
  "view_incremental_class_methods" => %w[view_spec.rb incremental_maintainer_spec.rb],
  "view_query_access_class_methods" => %w[view_spec.rb],
  "view_refresh_policy_class_methods" => %w[view_spec.rb view_refresh_on_change_spec.rb],
  "refresh_callbacks" => %w[refresher_spec.rb],
  "refresh_result" => %w[refresher_spec.rb],
  "metadata_record" => %w[metadata_spec.rb],
  "configuration" => :all,
  "railtie" => :all,
  "module_api" => :all,
  "type_reexports" => :all,
  "tasks" => :all
}.freeze

module AffectedSpecs
  module_function

  def fast_spec(name)
    File.join(FAST_SPEC_DIR, name)
  end

  def lib_entry_point?(path)
    ["lib/activerecord/materialized.rb", "lib/activerecord_materialized_types.rb"].include?(path)
  end

  def specs_from_override(base)
    case SPEC_OVERRIDES.fetch(base, :direct)
    when :all
      ALL_FAST_SPECS
    when Array
      SPEC_OVERRIDES.fetch(base).map { |name| fast_spec(name) }
    when :direct
      direct = fast_spec("#{base}_spec.rb")
      File.exist?(direct) ? [direct] : ALL_FAST_SPECS
    end
  end

  def specs_for_lib_file(path)
    return ALL_FAST_SPECS if lib_entry_point?(path)
    return [fast_spec("metadata_spec.rb")] if path.start_with?("lib/activerecord/materialized/metadata/")
    return [] unless path.start_with?("lib/")

    specs_from_override(File.basename(path, ".rb"))
  end

  def trigger_all_specs?(file)
    file.match?(%r{\A(spec/spec_helper\.rb|spec/support/)}) || file.match?(INFRA_TRIGGER)
  end

  def accumulate_specs!(specs, file)
    if file.end_with?("_spec.rb")
      specs << file unless file == HEAVY_SPEC
    elsif file.start_with?("lib/")
      specs.concat(specs_for_lib_file(file))
    end
  end

  def specs_for_files(files)
    specs = []
    trigger_all = files.any? { |file| trigger_all_specs?(file) }

    files.each { |file| accumulate_specs!(specs, file) } unless trigger_all

    trigger_all ? ALL_FAST_SPECS : specs.uniq.sort
  end
end

if $PROGRAM_NAME == __FILE__
  files = ARGV
  specs = files.empty? ? [] : AffectedSpecs.specs_for_files(files)
  puts specs.join(" ") unless specs.empty?
end
