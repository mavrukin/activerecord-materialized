<div class="rcol is-<%= kind %>">
  <div class="rhead">
    <span class="rlabel"><%= result.label %></span>
    <span class="rms"><%= number_with_delimiter result.ms %><small> ms</small></span>
  </div>
  <div class="rmeta"><%= number_with_delimiter result.row_count %> rows returned</div>
  <% if result.rows.any? %>
    <div class="tablewrap">
      <table>
        <thead><tr><% result.columns.each do |col| %><th><%= col %></th><% end %></tr></thead>
        <tbody>
          <% result.rows.each do |row| %>
            <tr><% result.columns.each do |col| %><td><%= row[col] %></td><% end %></tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if result.row_count > result.rows.size %>
      <div class="rmore">… and <%= number_with_delimiter(result.row_count - result.rows.size) %> more</div>
    <% end %>
  <% end %>
</div>
