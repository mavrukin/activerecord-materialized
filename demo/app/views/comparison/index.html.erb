<header class="hero">
  <h1>activerecord&#8209;materialized</h1>
  <p class="sub">
    Run the same analytical query the slow way and through a materialized view — <b>side by side</b>.
    Then mutate the data and watch the view go stale and catch back up.
  </p>
</header>

<section class="toolbar">
  <%= form_with url: select_db_path, method: :post, class: "dbform" do %>
    <label for="dbselect">Dataset</label>
    <select id="dbselect" name="path" onchange="this.form.requestSubmit()">
      <% @databases.each do |db| %>
        <option value="<%= db[:path] %>" <%= "selected" if db[:current] %> <%= "disabled" unless db[:available] %>>
          <%= db[:scale] %> — <%= db[:available] ? "#{db[:speedup]} faster" : "not generated" %>
        </option>
      <% end %>
    </select>
    <noscript><button type="submit">Switch</button></noscript>
  <% end %>
  <div class="stats">
    <div><b><%= number_with_delimiter @dataset[:cast_info] %></b><span>cast_info rows</span></div>
    <div><b><%= number_with_delimiter @dataset[:titles] %></b><span>titles</span></div>
    <div><b><%= number_with_delimiter @dataset[:names] %></b><span>names</span></div>
  </div>
</section>

<% missing = @databases.reject { |db| db[:available] } %>
<% if missing.any? %>
  <% target = missing.last %>
  <p class="hint">
    💡 The bigger the dataset, the more dramatic the win — <b>medium</b> is only ~50×, <b><%= target[:scale] %></b> is
    <b><%= target[:speedup] %></b>. Generate one from the repo root, then reload this page:
    <code><%= target[:command] %></code>
  </p>
<% end %>

<% if @notice.present? %><p class="notice"><%= @notice %></p><% end %>

<ol class="howto">
  <li><b>Compare</b> a fresh scenario — the view isn’t built, so it reads <i>through</i> to the source (correct, still slow).</li>
  <li><b>Build / refresh</b> it, then <b>Compare</b> again — same answer, now from the cache (orders of magnitude faster).</li>
  <li><b>Insert cast rows</b> — the view goes <b>out of sync</b> and refreshes itself in the background; watch the status pill reach <b>up to date</b>, then <b>Compare</b> to confirm.</li>
</ol>

<% @scenarios.each do |scenario| %>
  <% status = scenario_status(scenario) %>
  <% active = @active == scenario.key %>
  <section class="card<%= ' active' if active %>" id="s-<%= scenario.key %>">
    <header>
      <div>
        <span class="tag"><%= scenario.complexity %></span>
        <h2><%= scenario.label %></h2>
      </div>
      <span class="pill <%= status[:css] %>" data-key="<%= scenario.key %>" data-state="<%= status[:state] %>"><%= status[:label] %></span>
    </header>
    <p class="desc"><%= scenario.description %></p>
    <details class="sql">
      <summary>Show the query &middot; <code><%= scenario.view_name %></code></summary>
      <pre><%= scenario.sql %></pre>
    </details>
    <div class="actions">
      <%= form_with url: compare_path(scenario.key), method: :post do %>
        <button class="primary" type="submit">&#9654;&nbsp; Compare raw vs view</button>
      <% end %>
      <%= form_with url: refresh_path(scenario.key), method: :post do %>
        <button type="submit">Build / refresh</button>
      <% end %>
      <% if scenario.affected_by_mutation? %>
        <%= form_with url: mutate_path(scenario.key), method: :post do %>
          <button type="submit">Insert cast rows</button>
        <% end %>
      <% end %>
      <% if scenario.view_class.materialized? %>
        <%= form_with url: reset_path(scenario.key), method: :post do %>
          <button class="ghost" type="submit">Reset to cold</button>
        <% end %>
      <% end %>
    </div>
    <% if active && @comparison %>
      <%= render "comparison", comparison: @comparison %>
    <% end %>
  </section>
<% end %>

<% if @active.present? %>
  <script>
    document.getElementById("s-<%= @active %>")?.scrollIntoView({ behavior: "smooth", block: "center" });
  </script>
<% end %>

<script>
  // Poll view freshness so the status pills update live as a background refresh
  // runs (out of sync -> syncing -> up to date), without reloading the page.
  (function () {
    const transitional = new Set(["dirty", "syncing"]);
    let timer = null;

    async function poll() {
      let active = false;
      try {
        const res = await fetch("<%= status_path %>", { headers: { Accept: "application/json" } });
        const data = await res.json();
        for (const [key, st] of Object.entries(data)) {
          const pill = document.querySelector('.pill[data-key="' + key + '"]');
          if (pill) { pill.textContent = st.label; pill.className = "pill " + st.css; pill.dataset.state = st.state; }
          if (transitional.has(st.state)) active = true;
        }
      } catch (_e) { /* keep trying */ }
      timer = active ? setTimeout(poll, 1200) : null;
    }

    function maybeStart() {
      if (timer) return;
      const anyTransitional = [...document.querySelectorAll(".pill[data-state]")]
        .some((p) => transitional.has(p.dataset.state));
      if (anyTransitional) poll();
    }

    maybeStart();
    // After a mutate the page reloads with a transitional pill; also re-check
    // when the tab regains focus.
    document.addEventListener("visibilitychange", () => { if (!document.hidden) maybeStart(); });
  })();
</script>
